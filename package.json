{
  "name": "@seungwoolee/agent-tree",
  "version": "0.1.1",
  "description": "Navigate any Claude Code (and future Codex/Gemini) session as a numbered tree in your terminal and resume from any node.",
  "license": "MIT",
  "author": "Seungwoo Lee",
  "homepage": "https://github.com/lifrary/agent-tree",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lifrary/agent-tree.git"
  },
  "bugs": {
    "url": "https://github.com/lifrary/agent-tree/issues"
  },
  "type": "module",
  "bin": {
    "agent-tree": "./dist/cli.js",
    "atree": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist/",
    ".claude-plugin/",
    "skills/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "tsc --noEmit --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "cli": "tsx src/cli.ts",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.1",
    "pino": "^9.5.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.90.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mindmap",
    "session",
    "visualizer",
    "cli"
  ]
}
